extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1= title
    a.btn.btn-success(href="/grupos-geminados/novo") + Novo Grupo

  if grupos && grupos.length
    each grupo in grupos
      .card.mb-3
        .card-header.d-flex.justify-content-between.align-items-center
          h5.mb-0= grupo.nome
          form(action=`/grupos-geminados/deletar/${grupo.id}`, method="POST", onsubmit="return confirm('Tem certeza?');")
            button.btn.btn-sm.btn-danger(type="submit") Deletar
        .card-body
          p
            strong Disciplina: 
            | #{grupo.Disciplina.nome}
          p
            strong Professor: 
            | #{grupo.Professor.nome}
          p
            strong Turmas: 
            each turma, index in grupo.turmas
              span.badge.bg-secondary.me-1= turma.nome
  else
    p.text-muted Nenhum grupo de aulas geminadas cadastrado.