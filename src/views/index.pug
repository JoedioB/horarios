extends layout

block content
  .p-5.mb-4.bg-light.rounded-3
    .container-fluid.py-5
      h1.display-5.fw-bold Bem-vindo ao Gerador de Horários!
      p.col-md-8.fs-4
        | Cadastre professores, disciplinas e turmas. Depois, clique no botão abaixo para gerar o quadro de horários automaticamente.
      form#form-gerar(action="/horarios/gerar" method="POST")
        button#btn-gerar.btn.btn-primary.btn-lg(type="submit" onclick="this.innerHTML='Gerando Horário... Por favor aguarde...'; this.disabled=true; document.getElementById('form-gerar').submit();") Gerar Horário Automático

  hr

  h2.mt-5 Ver Horários por Turma
  if turmas && turmas.length > 0
    .list-group
      each turma in turmas
        a.list-group-item.list-group-item-action(href=`/horarios/turma/${turma.id}`)= `Turma ${turma.nome} - ${turma.ano}`
  else
    p.text-muted Nenhuma turma cadastrada.